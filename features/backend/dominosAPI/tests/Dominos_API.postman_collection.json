      "name": "Create Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.cartId) {",
              "    pm.collectionVariables.set('cartId', json.cartId);",
              "    console.log('cartId saved:', json.cartId);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/dominos/cart",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "dominos",
            "cart"
          ]
        },
        "description": "Create a new cart. Returns { cartId }."
      },
      "response": []
